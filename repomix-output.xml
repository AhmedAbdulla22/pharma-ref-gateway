  "clarithromycin": "clarithromycin",
  "doxycycline": "doxycycline",
  "metronidazole": "metronidazole",
  "ciprofloxacin": "ciprofloxacin",
  "trimethoprim": "trimethoprim",
  
  "atenolol": "atenolol",
  "bisoprolol": "bisoprolol",
