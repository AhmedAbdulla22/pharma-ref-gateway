           {/* ID / QR */}
           <Card>
            <CardHeader>
              <CardTitle className={`flex items-center gap-2 text-lg ${isRTL ? "flex-row-reverse" : ""}`}>
                <QrCode className="h-5 w-5 text-primary" />
