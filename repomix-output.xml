export const DRUG_NAME_TRANSLATIONS: Record<string, string> = {
  "paracetamol": "acetaminophen",
  "co-codamol": "acetaminophen with codeine",
  "cocodamol": "acetaminophen with codeine",
  "ibuprofen": "ibuprofen",
